# EZ Tax Backend Configuration

# Gmail Credentials (IMAP and SMTP)
# IMPORTANT: Use an App Password from Google Account Security, NOT your main password.
EMAIL_USER=contact.ez.security@gmail.com
EMAIL_PASS=your_gmail_app_password

# AI Settings (Gemini API Key from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key

# Paths and Port
PORT=3000
UPLOADS_DIR=./uploads
COMPLETED_DIR=./completed_cases
